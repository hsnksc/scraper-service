# -----------------------------------------------
# Scraper Servisi — Ortam Değişkenleri
# Bu dosyayı kopyalayıp ".env" olarak kaydedin:
#   cp .env.example .env
# -----------------------------------------------

# --- Servis kimlik doğrulama ---
SCRAPER_API_KEY=change_me_strong_key_here

# --- Arama API Anahtarları (en az biri zorunlu) ---
TAVILY_API_KEY=
EXA_API_KEY=
SERPER_API_KEY=

# --- Discovery ayarları ---
DISCOVERY_PROVIDER_QUERY_LIMIT=3
DISCOVERY_MAX_RESULTS_PER_PROVIDER=10
DISCOVERY_PROVIDER_TIMEOUT_SECONDS=8
DISCOVERY_TIMEOUT_SECONDS=55

# --- Çıktı sınırı ---
MARKET_ROWS_LIMIT=80
