OPENAI_API_KEY=your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
TAVILY_API_KEY=your-tavily-api-key-here
SERPER_API_KEY=your-serper-api-key-here
EXA_API_KEY=your-exa-api-key-here
EXA_SEARCH_TYPE=auto

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DELAY_MIN=0.0
PLAYWRIGHT_DELAY_MAX=0.1
MAX_CONCURRENT_PAGES=8
PLAYWRIGHT_NAV_TIMEOUT_MS=15000
PLAYWRIGHT_DOMCONTENT_TIMEOUT_MS=4000
MAX_LISTING_URLS=10
MAX_LINKS_PER_SEED=5
MAX_OUTPUT_LISTINGS=8
STRICT_DETAIL_ONLY=true
STRICT_DISTRICT_HEADER=true
DISCOVERY_TIMEOUT_SECONDS=55
DISCOVERY_FAST_QUERY_LIMIT=4
DISCOVERY_PROVIDER_QUERY_LIMIT=3
DISCOVERY_MAX_RESULTS_PER_PROVIDER=10
DISCOVERY_PROVIDER_TIMEOUT_SECONDS=8
DISCOVERY_OUTPUT_LIMIT=60
MARKET_ROWS_LIMIT=80

EXTERNAL_API_URL=https://api.example.com/v1/listings
EXTERNAL_API_KEY=your-api-key-here
EXTERNAL_API_AUTH_HEADER=Authorization
EXTERNAL_API_BATCH_SIZE=50
